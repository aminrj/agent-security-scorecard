# Beehiiv newsletter integration (optional — PDF still generates without it)
# Get these from your Beehiiv dashboard → Settings → API
#
# WARNING: For production, proxy the Beehiiv API through a serverless function
# so your API key is never exposed to the browser. For MVP/dev, these values
# work directly but should be treated as low-security keys with subscribe-only scope.
VITE_BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_BEEHIIV_API_KEY=
